---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'moooon — three products, one small team',
  description = 'moooon builds Doooo App, Doooo Hub, and Prodect. We use the workflow Prodect codifies to build all three.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://moooon.net" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
  </head>
  <body class="bg-[var(--color-paper)] text-[var(--color-ink)] font-sans">
    <slot />
  </body>
</html>
