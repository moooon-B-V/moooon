---
import BrandDoooo from './BrandDoooo.astro';
---

<section class="mx-auto max-w-6xl px-6 md:px-10 py-12 md:py-16">
  <div class="grid md:grid-cols-12 gap-8 md:gap-10 items-start">
    <header class="md:col-span-4">
      <p class="text-[11px] uppercase tracking-[0.18em] text-[var(--color-muted)]">When you connect them</p>
      <h3 class="font-display mt-3 text-[28px] md:text-[36px] leading-[1.1] tracking-[-0.02em] font-medium">
        The app is the remote.<br />The desktop does the work.
      </h3>
      <p class="mt-4 text-[15px] md:text-[16px] text-[var(--color-muted)] leading-[1.55]">
        <BrandDoooo /> App can hand a task to a <BrandDoooo /> Hub team. Connect them once — like any other
        integration — then assign work from your phone, watch the agents run on your Mac, get the result back
        when they're done.
      </p>
    </header>

    <div class="md:col-span-8">
      <div class="ahid-frame relative rounded-2xl border border-[var(--color-line)]/15 bg-gradient-to-br from-[#fff5ee] via-[#fff8f0] to-[#f0eeff] p-4 md:p-8 shadow-[0_2px_8px_-2px_rgba(10,10,10,0.05),0_24px_60px_-32px_rgba(54,14,255,0.18)]">
        <div class="grid grid-cols-1 md:grid-cols-[200px_1fr_320px] gap-4 md:gap-5 items-center justify-items-center">

          <!-- ===== Phone (left on desktop, top on mobile) ===== -->
          <div class="phone w-[180px] md:w-full rounded-[24px] border border-black/10 bg-white shadow-[0_24px_50px_-24px_rgba(10,10,10,0.25)] overflow-hidden relative h-[300px] md:h-[340px]">
            <!-- Status bar -->
            <div class="flex items-center justify-between px-3 pt-2 pb-1.5 text-[9px] text-[var(--color-muted)]">
              <span>9:41</span>
              <span class="w-3.5 h-1.5 rounded-sm bg-[var(--color-ink)]/50"></span>
            </div>
            <!-- App header -->
            <div class="px-3 pb-2 border-b border-black/5 flex items-center gap-1.5">
              <span class="text-[9px] uppercase tracking-[0.14em] text-[var(--color-muted)]"><BrandDoooo /></span>
              <span class="ml-auto text-[8px] text-[var(--color-muted)]">Tasks</span>
            </div>

            <!-- Phone screens -->
            <div class="relative h-[calc(100%-44px)]">
              <!-- Screen 1: inbox -->
              <div class="phone-screen ps-1 absolute inset-0 px-3 py-2.5 space-y-1.5">
                <div class="text-[8px] uppercase tracking-[0.14em] text-[var(--color-muted)] mb-1.5">Today</div>
                <div class="task-row task-row-tap rounded-md border border-[var(--color-brand)]/30 bg-[var(--color-brand)]/5 px-2 py-1.5 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-brand)]"></span>
                  <span class="text-[10px] font-semibold">Draft launch post</span>
                </div>
                <div class="rounded-md border border-black/5 bg-[var(--color-paper-2)] px-2 py-1.5 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-ink)]/30"></span>
                  <span class="text-[10px] text-[var(--color-muted)]">Reply to mom</span>
                </div>
                <div class="rounded-md border border-black/5 bg-[var(--color-paper-2)] px-2 py-1.5 flex items-center gap-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-ink)]/30"></span>
                  <span class="text-[10px] text-[var(--color-muted)]">Pick up groceries</span>
                </div>
              </div>

              <!-- Screen 2: assign sheet -->
              <div class="phone-screen ps-2 absolute inset-0 px-3 py-2.5">
                <div class="rounded-lg border border-[var(--color-brand)]/30 bg-[var(--color-brand)]/[0.04] p-2.5">
                  <div class="text-[10px] font-semibold mb-1">Draft launch post</div>
                  <div class="text-[8px] text-[var(--color-muted)] mb-2">Assign to →</div>
                  <div class="rounded-md border border-[var(--color-brand)]/40 bg-white px-2 py-1.5 flex items-center gap-2">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--color-brand)]">
                      <rect x="3" y="4" width="18" height="14" rx="2"/>
                      <path d="M8 22h8"/>
                    </svg>
                    <span class="text-[9px] font-semibold"><BrandDoooo /> Hub</span>
                  </div>
                  <div class="mt-1 text-[8px] text-[var(--color-muted)] ml-5">Content Creator team</div>
                </div>
              </div>

              <!-- Screen 3: sent / working -->
              <div class="phone-screen ps-3 absolute inset-0 px-3 py-2.5 space-y-2">
                <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-2 py-1.5 flex items-center gap-2">
                  <span class="text-emerald-600 text-[10px]">✓</span>
                  <span class="text-[9px] text-emerald-900 font-semibold">Sent to Hub</span>
                </div>
                <div class="rounded-lg border border-black/5 bg-[var(--color-paper-2)] px-2 py-2">
                  <div class="text-[9px] font-semibold mb-1">Draft launch post</div>
                  <div class="text-[8px] text-[var(--color-muted)] mb-1.5">Content Creator team · working</div>
                  <div class="h-1 bg-black/5 rounded-full overflow-hidden">
                    <div class="progress-bar h-full bg-[var(--color-brand)] rounded-full"></div>
                  </div>
                  <div class="mt-1 text-[8px] text-[var(--color-muted)] flex justify-between">
                    <span class="progress-label">Researching…</span>
                    <span class="progress-pct">25%</span>
                  </div>
                </div>
              </div>

              <!-- Screen 4: done notification -->
              <div class="phone-screen ps-4 absolute inset-0 px-3 py-2.5 space-y-2">
                <div class="rounded-lg border border-[var(--color-brand)]/30 bg-white shadow-[0_8px_24px_-12px_rgba(54,14,255,0.3)] px-2.5 py-2">
                  <div class="flex items-center gap-1.5 mb-1">
                    <span class="text-[9px] text-emerald-600">●</span>
                    <span class="text-[8px] uppercase tracking-[0.14em] text-[var(--color-muted)] font-semibold">Hub</span>
                    <span class="ml-auto text-[8px] text-[var(--color-muted)]">now</span>
                  </div>
                  <div class="text-[10px] font-semibold mb-0.5">Draft is ready</div>
                  <div class="text-[8px] text-[var(--color-muted)] mb-2">280 chars · 1.2k article · scheduled to X, LinkedIn, Threads</div>
                  <div class="flex gap-1.5">
                    <div class="text-[8px] text-[var(--color-brand)] font-semibold">Review →</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- ===== Connector (between devices) ===== -->
          <div class="relative flex items-center justify-center w-3 h-12 md:w-full md:h-[340px]">
            <!-- Vertical connector on mobile. Drawn bottom-to-top so the
                 dashoffset animation reads as "data flowing downward toward the Mac". -->
            <svg viewBox="0 0 12 100" preserveAspectRatio="none" class="w-3 h-full md:hidden">
              <line class="connector-idle" x1="6" y1="100" x2="6" y2="0" stroke="#0a0a0a" stroke-opacity="0.15" stroke-width="0.6" stroke-dasharray="1.5 1.5"/>
              <line class="connector-active" x1="6" y1="100" x2="6" y2="0" stroke="#360eff" stroke-width="1" stroke-dasharray="4 3"/>
            </svg>
            <!-- Horizontal connector on desktop -->
            <svg viewBox="0 0 100 12" preserveAspectRatio="none" class="hidden md:block w-full h-3">
              <line class="connector-idle" x1="0" y1="6" x2="100" y2="6" stroke="#0a0a0a" stroke-opacity="0.15" stroke-width="0.6" stroke-dasharray="1.5 1.5"/>
              <line class="connector-active" x1="0" y1="6" x2="100" y2="6" stroke="#360eff" stroke-width="1" stroke-dasharray="4 3"/>
            </svg>
            <!-- Direction label (desktop only) -->
            <div class="hidden md:block absolute -top-1 text-[8px] uppercase tracking-[0.18em] text-[var(--color-muted)] connector-label">
              integration
            </div>
          </div>

          <!-- ===== Mac (right on desktop, below on mobile) ===== -->
          <div class="mac w-full md:w-full max-w-[320px] md:max-w-none rounded-xl border border-black/10 bg-[#0d0d18] overflow-hidden shadow-[0_30px_60px_-30px_rgba(10,10,10,0.4)] relative h-[300px] md:h-[340px]">
            <!-- Title bar -->
            <div class="flex items-center gap-1.5 px-3 py-1.5 border-b border-white/10">
              <span class="w-2 h-2 rounded-full bg-[#ff5f57]"></span>
              <span class="w-2 h-2 rounded-full bg-[#febc2e]"></span>
              <span class="w-2 h-2 rounded-full bg-[#28c840]"></span>
              <span class="ml-2 text-[9px] font-mono text-white/40"><BrandDoooo />-hub</span>
              <span class="ml-auto text-[8px] text-white/40">MLX · Local</span>
            </div>

            <!-- Hub status banner -->
            <div class="px-3 py-2 border-b border-white/10 bg-white/[0.02]">
              <div class="flex items-center gap-1.5">
                <span class="hub-status-dot w-1.5 h-1.5 rounded-full bg-white/30"></span>
                <span class="text-[9px] text-white/70">
                  <span class="hub-status-idle">Content Creator team · idle</span>
                  <span class="hub-status-active">Content Creator team · running</span>
                </span>
              </div>
            </div>

            <!-- Agents grid -->
            <div class="grid grid-cols-4 gap-px bg-white/5 px-px">
              <div class="bg-[#0d0d18] py-2 flex flex-col items-center gap-1 relative">
                <div class="hub-agent-dot hub-agent-1 w-1.5 h-1.5 rounded-full bg-white/15"></div>
                <div class="text-[8px] text-white/70">Researcher</div>
              </div>
              <div class="bg-[#0d0d18] py-2 flex flex-col items-center gap-1 relative">
                <div class="hub-agent-dot hub-agent-2 w-1.5 h-1.5 rounded-full bg-white/15"></div>
                <div class="text-[8px] text-white/70">Copywriter</div>
              </div>
              <div class="bg-[#0d0d18] py-2 flex flex-col items-center gap-1 relative">
                <div class="hub-agent-dot hub-agent-3 w-1.5 h-1.5 rounded-full bg-white/15"></div>
                <div class="text-[8px] text-white/70">Editor</div>
              </div>
              <div class="bg-[#0d0d18] py-2 flex flex-col items-center gap-1 relative">
                <div class="hub-agent-dot hub-agent-4 w-1.5 h-1.5 rounded-full bg-white/15"></div>
                <div class="text-[8px] text-white/70">Social</div>
              </div>
            </div>

            <!-- Activity log -->
            <div class="px-3 py-2.5 font-mono text-[9px] text-white/60 space-y-0.5 min-h-[120px]">
              <div class="hub-log hub-log-1"><span class="text-emerald-400">→</span> Received from <BrandDoooo /> App</div>
              <div class="hub-log hub-log-2"><span class="text-emerald-400">→</span> Researcher · 5 sources pulled</div>
              <div class="hub-log hub-log-3"><span class="text-emerald-400">→</span> Copywriter · 280-char post drafted</div>
              <div class="hub-log hub-log-4"><span class="text-emerald-400">→</span> Editor · tone pass, fact-check passed</div>
              <div class="hub-log hub-log-5"><span class="text-emerald-400">→</span> Social · scheduled X 9a · LI 10a · Threads 11a</div>
              <div class="hub-log hub-log-6 text-emerald-400">✓ Sent back to <BrandDoooo /> App · 41s</div>
            </div>
          </div>
        </div>

        <p class="mt-5 text-center text-[12px] text-[var(--color-muted)] leading-[1.5]">
          Connect once — like any other integration — then assign from the app, watch Hub run it on your Mac.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  /* 15s total loop */
  .phone-screen {
    opacity: 0;
    animation: ahid-screen-cycle 15s ease-in-out infinite;
  }
  .ps-1 { animation-delay: 0s; }
  .ps-2 { animation-delay: 3s; }
  .ps-3 { animation-delay: 5s; }
  .ps-4 { animation-delay: 12s; }

  @keyframes ahid-screen-cycle {
    0%, 1%    { opacity: 0; transform: translateY(6px); }
    2%, 18%   { opacity: 1; transform: translateY(0); }
    20%, 100% { opacity: 0; transform: translateY(-6px); }
  }

  /* Task-row tap effect: pulses just before screen 2 takes over */
  .task-row-tap { transform-origin: center; }
  .task-row-tap {
    animation: ahid-tap 15s ease-in-out infinite;
  }
  @keyframes ahid-tap {
    0%, 17%   { transform: scale(1); box-shadow: 0 0 0 0 rgba(54,14,255, 0); }
    18%, 19%  { transform: scale(0.96); box-shadow: 0 0 0 6px rgba(54,14,255, 0.15); }
    20%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(54,14,255, 0); }
  }

  /* Progress bar fills during working screen */
  .progress-bar {
    width: 0;
    animation: ahid-progress 15s linear infinite;
  }
  @keyframes ahid-progress {
    0%, 33%  { width: 0; }
    36%      { width: 25%; }
    50%      { width: 60%; }
    65%      { width: 85%; }
    78%      { width: 100%; }
    80%, 100% { width: 100%; }
  }

  /* Connector goes active during the working / done phase */
  .connector-idle  { animation: ahid-conn-idle 15s linear infinite; }
  .connector-active{ animation: ahid-conn-active 15s linear infinite; stroke-dashoffset: 0; }
  @keyframes ahid-conn-idle {
    0%, 30%   { opacity: 1; }
    33%, 82%  { opacity: 0; }
    85%, 100% { opacity: 1; }
  }
  @keyframes ahid-conn-active {
    0%, 30%   { opacity: 0; stroke-dashoffset: 0; }
    33%, 82%  { opacity: 1; stroke-dashoffset: -70; }
    85%, 100% { opacity: 0; stroke-dashoffset: -70; }
  }
  .connector-label {
    animation: ahid-conn-label 15s linear infinite;
  }
  @keyframes ahid-conn-label {
    0%, 30%   { color: var(--color-muted); }
    33%, 82%  { color: var(--color-brand); }
    85%, 100% { color: var(--color-muted); }
  }

  /* Hub status text crossfade */
  .hub-status-idle, .hub-status-active { display: inline-block; }
  .hub-status-active { display: none; }
  .hub-status-idle   { animation: ahid-hub-idle 15s linear infinite; }
  .hub-status-active { animation: ahid-hub-active 15s linear infinite; display: inline-block; opacity: 0; }
  @keyframes ahid-hub-idle {
    0%, 32%   { opacity: 1; display: inline; }
    33%, 82%  { opacity: 0; }
    85%, 100% { opacity: 1; }
  }
  @keyframes ahid-hub-active {
    0%, 32%   { opacity: 0; }
    33%, 82%  { opacity: 1; }
    85%, 100% { opacity: 0; }
  }
  .hub-status-dot {
    animation: ahid-hub-dot 15s linear infinite;
  }
  @keyframes ahid-hub-dot {
    0%, 32%   { background-color: rgba(255,255,255,0.3); box-shadow: none; }
    33%, 82%  { background-color: rgb(52, 211, 153); box-shadow: 0 0 8px rgba(52, 211, 153, 0.7); }
    85%, 100% { background-color: rgba(255,255,255,0.3); box-shadow: none; }
  }

  /* Agents light up in sequence during active window (5s → 11s) */
  .hub-agent-dot {
    animation: ahid-agent 15s ease-in-out infinite;
  }
  .hub-agent-1 { animation-delay: 0s; }
  .hub-agent-2 { animation-delay: 1.5s; }
  .hub-agent-3 { animation-delay: 3s; }
  .hub-agent-4 { animation-delay: 4.5s; }
  @keyframes ahid-agent {
    0%, 33%   { background-color: rgba(255,255,255,0.15); box-shadow: none; }
    35%, 45%  { background-color: rgb(52, 211, 153); box-shadow: 0 0 6px rgba(52, 211, 153, 0.7); }
    47%, 82%  { background-color: rgba(52, 211, 153, 0.5); box-shadow: none; }
    85%, 100% { background-color: rgba(255,255,255,0.15); box-shadow: none; }
  }

  /* Hub log lines */
  .hub-log {
    opacity: 0;
    transform: translateY(3px);
    animation: ahid-log 15s ease-out infinite;
  }
  .hub-log-1 { animation-delay: 5.0s; }
  .hub-log-2 { animation-delay: 6.0s; }
  .hub-log-3 { animation-delay: 7.5s; }
  .hub-log-4 { animation-delay: 9.0s; }
  .hub-log-5 { animation-delay: 10.5s; }
  .hub-log-6 { animation-delay: 11.5s; }
  @keyframes ahid-log {
    0%, 33%   { opacity: 0; transform: translateY(3px); }
    35%, 80%  { opacity: 1; transform: translateY(0); }
    82%, 100% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-screen, .task-row-tap, .progress-bar, .connector-idle, .connector-active,
    .connector-label, .hub-status-idle, .hub-status-active, .hub-status-dot,
    .hub-agent-dot, .hub-log {
      animation: none !important;
    }
    .phone-screen.ps-3 { opacity: 1; }
    .progress-bar { width: 70%; }
    .hub-status-active { opacity: 1; }
    .hub-status-idle { opacity: 0; }
    .hub-agent-dot { background-color: rgb(52, 211, 153); }
    .hub-log { opacity: 1; transform: none; }
  }
</style>
