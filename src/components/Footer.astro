---
import BrandDoooo from './BrandDoooo.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-line)]/10 mt-24">
  <div class="mx-auto max-w-6xl px-6 md:px-10 py-12 md:py-16 grid md:grid-cols-12 gap-8">
    <div class="md:col-span-5">
      <p class="font-display text-[15px] tracking-[0.04em] font-semibold">MOOOON</p>
      <p class="mt-2 text-[13px] text-[var(--color-muted)] max-w-md leading-[1.55]">
        We build tools we wished existed and ship them when they're ready.
      </p>
    </div>
    <div class="md:col-span-3 text-[13px] space-y-2">
      <p class="text-[var(--color-muted)] uppercase tracking-[0.14em] text-[11px] mb-3">Products</p>
      <a href="/#doooo-app" class="block hover:text-[var(--color-brand)] transition-colors"><BrandDoooo /> App</a>
      <a href="/#doooo-hub" class="block hover:text-[var(--color-brand)] transition-colors"><BrandDoooo /> Hub</a>
      <a href="/#prodect" class="block hover:text-[var(--color-brand)] transition-colors">Prodect</a>
    </div>
    <div class="md:col-span-2 text-[13px] space-y-2">
      <p class="text-[var(--color-muted)] uppercase tracking-[0.14em] text-[11px] mb-3">Company</p>
      <a href="mailto:info@moooon.net" class="block hover:text-[var(--color-brand)] transition-colors">Contact</a>
      <a href="https://github.com/moooon-B-V" target="_blank" rel="noopener" class="block hover:text-[var(--color-brand)] transition-colors">GitHub</a>
    </div>
    <div class="md:col-span-2 text-[13px] space-y-2">
      <p class="text-[var(--color-muted)] uppercase tracking-[0.14em] text-[11px] mb-3">Legal</p>
      <a href="/privacy" class="block hover:text-[var(--color-brand)] transition-colors">Privacy</a>
      <a
        href="https://www.iubenda.com/privacy-policy/73390507/cookie-policy"
        class="iubenda-embed iubenda-nostyle no-brand block hover:text-[var(--color-brand)] transition-colors cursor-pointer"
        title="Cookie Policy"
      >Cookies</a>
      <a href="/terms" class="block hover:text-[var(--color-brand)] transition-colors">Terms</a>
      <a href="/imprint" class="block hover:text-[var(--color-brand)] transition-colors">Imprint</a>
    </div>
  </div>
  <div class="border-t border-[var(--color-line)]/10">
    <div class="mx-auto max-w-6xl px-6 md:px-10 py-5 flex items-center justify-between text-[11px] text-[var(--color-muted)] uppercase tracking-[0.14em]">
      <span>© {year} MOOOON</span>
      <span>Built by the tool we're building</span>
    </div>
  </div>
</footer>
