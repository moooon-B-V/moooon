---
import BrandDoooo from './BrandDoooo.astro';
import { t, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
---

<figure class="not-prose my-8">
  <div
    class="relative overflow-hidden rounded-2xl border border-[var(--color-line)]/15 bg-gradient-to-br from-[#0a0a0a] via-[#171528] to-[#1a0f2e] p-5 md:p-7 shadow-[0_30px_70px_-30px_rgba(54,14,255,0.4)]"
  >
    <!-- Desktop-window-style mockup -->
    <div class="rounded-xl border border-white/10 bg-black/40 backdrop-blur-sm overflow-hidden">
      <!-- Title bar -->
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-white/10 bg-black/40">
        <span class="w-2.5 h-2.5 rounded-full bg-[#ff5f57]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#febc2e]"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-[#28c840]"></span>
        <span class="ml-3 text-[11px] text-white/40 font-mono">{t(lang, 'twTitle')}</span>
        <span class="ml-auto text-[10px] text-white/40">{t(lang, 'twMeta')}</span>
      </div>

      <!-- Goal -->
      <div class="px-5 py-3 border-b border-white/10 bg-white/[0.02]">
        <span class="text-[10px] uppercase tracking-[0.18em] text-white/40">{t(lang, 'twGoalKicker')}</span>
        <div class="text-[13px] text-white/90 mt-0.5">
          {t(lang, 'twGoal')}
        </div>
      </div>

      <!-- Agents grid -->
      <div class="grid grid-cols-4 gap-px bg-white/5">
        <div class="agent-card agent-card-1 bg-black/40 px-3 py-4 flex flex-col items-center gap-2 relative">
          <div class="agent-dot agent-dot-1 w-2 h-2 rounded-full bg-emerald-400"></div>
          <div class="text-[11px] font-semibold text-white/90">{t(lang, 'twAgent1Name')}</div>
          <div class="text-[10px] text-white/40 text-center leading-tight">{t(lang, 'twAgent1Sub1')}<br/>{t(lang, 'twAgent1Sub2')}</div>
          <div class="agent-output agent-output-1 absolute -bottom-1 left-2 right-2 h-0.5 bg-emerald-400/60 rounded-full"></div>
        </div>
        <div class="agent-card agent-card-2 bg-black/40 px-3 py-4 flex flex-col items-center gap-2 relative">
          <div class="agent-dot agent-dot-2 w-2 h-2 rounded-full bg-white/15"></div>
          <div class="text-[11px] font-semibold text-white/90">{t(lang, 'twAgent2Name')}</div>
          <div class="text-[10px] text-white/40 text-center leading-tight">{t(lang, 'twAgent2Sub1')}<br/>{t(lang, 'twAgent2Sub2')}</div>
          <div class="agent-output agent-output-2 absolute -bottom-1 left-2 right-2 h-0.5 bg-emerald-400/60 rounded-full"></div>
        </div>
        <div class="agent-card agent-card-3 bg-black/40 px-3 py-4 flex flex-col items-center gap-2 relative">
          <div class="agent-dot agent-dot-3 w-2 h-2 rounded-full bg-white/15"></div>
          <div class="text-[11px] font-semibold text-white/90">{t(lang, 'twAgent3Name')}</div>
          <div class="text-[10px] text-white/40 text-center leading-tight">{t(lang, 'twAgent3Sub1')}<br/>{t(lang, 'twAgent3Sub2')}</div>
          <div class="agent-output agent-output-3 absolute -bottom-1 left-2 right-2 h-0.5 bg-emerald-400/60 rounded-full"></div>
        </div>
        <div class="agent-card agent-card-4 bg-black/40 px-3 py-4 flex flex-col items-center gap-2 relative">
          <div class="agent-dot agent-dot-4 w-2 h-2 rounded-full bg-white/15"></div>
          <div class="text-[11px] font-semibold text-white/90">{t(lang, 'twAgent4Name')}</div>
          <div class="text-[10px] text-white/40 text-center leading-tight">{t(lang, 'twAgent4Sub1')}<br/>{t(lang, 'twAgent4Sub2')}</div>
          <div class="agent-output agent-output-4 absolute -bottom-1 left-2 right-2 h-0.5 bg-emerald-400/60 rounded-full"></div>
        </div>
      </div>

      <!-- Activity log -->
      <div class="px-5 py-4 bg-black/40 border-t border-white/10 min-h-[140px] font-mono text-[11px] text-white/60 space-y-1">
        <div class="log-line log-1">
          <span class="text-emerald-400">→</span> {t(lang, 'twLog1')}
        </div>
        <div class="log-line log-2">
          <span class="text-emerald-400">→</span> {t(lang, 'twLog2')}
        </div>
        <div class="log-line log-3">
          <span class="text-emerald-400">→</span> {t(lang, 'twLog3')}
        </div>
        <div class="log-line log-4">
          <span class="text-emerald-400">→</span> {t(lang, 'twLog4')}
        </div>
        <div class="log-line log-5 text-white/90">
          <span class="text-emerald-400">✓</span> {t(lang, 'twLog5')}
        </div>
      </div>
    </div>

    <figcaption class="mt-5 text-center text-[12px] text-white/60 leading-[1.5]">
      <span class="text-white font-medium">{t(lang, 'twCaptionBefore')}</span>
      {t(lang, 'twCaptionPre')}<BrandDoooo />{t(lang, 'twCaptionPost')}
    </figcaption>
  </div>

  <style>
    /*
      ============================================================
      Animation timing — single 14s master loop, hard reset.
      ============================================================

      Each element animates over the SAME 14s duration so all
      iterations stay synchronized. The animation-delay is NEGATIVE
      (not positive) — that means each element starts "partway
      through" its first iteration so the visual sequence appears
      staggered, but every element resets at the same absolute clock.

      Result: at t=14s (and every 14s thereafter) every element
      simultaneously returns to its 0%/100% state — i.e. idle.
      The "all four bars filled" moment exists only briefly around
      t=12-13.5s, then everything resets together.
    */

    .agent-dot {
      animation: dot-active 14s ease-in-out infinite;
    }
    .agent-dot-1 { animation-delay: 0s; }
    .agent-dot-2 { animation-delay: -10.5s; } /* runs 3.5s ahead of 14s loop → starts visually 3.5s later */
    .agent-dot-3 { animation-delay: -7s; }
    .agent-dot-4 { animation-delay: -3.5s; }

    /* Wait — negative delay moves the *animation phase*, not the visual stagger we want.
       For a staggered start with synchronized reset, the right pattern is:
         - Same duration on every element
         - Per-element positive delay
         - First iteration has the delay, all later iterations are synced
       The problem: CSS doesn't natively give you "delay only on first iteration."
       The fix: structure the keyframe so that the "active" phase is small relative
       to the loop, and the rest is idle. The visual stagger comes from each agent's
       keyframe placing its active window at a different % of the loop.
       Below: agent-1 active 0-25%, agent-2 active 25-50%, etc. All elements
       share the same animation-delay = 0. */

    .agent-dot {
      animation: dot-active 14s linear infinite;
      animation-delay: 0s !important;
    }
    .agent-dot-1 { animation-name: agent1-dot; }
    .agent-dot-2 { animation-name: agent2-dot; }
    .agent-dot-3 { animation-name: agent3-dot; }
    .agent-dot-4 { animation-name: agent4-dot; }

    /* Agent-N becomes active at (N-1)*21% of the loop, holds at "done" until 90%,
       fades back to idle by 100%. Final 10% of the loop is the visible "reset" window. */

    @keyframes agent1-dot {
      0%        { background-color: rgba(255,255,255,0.15); box-shadow: none; }
      2%, 18%   { background-color: rgb(52, 211, 153); box-shadow: 0 0 10px rgba(52, 211, 153, 0.7); }
      22%, 90%  { background-color: rgba(52, 211, 153, 0.5); box-shadow: none; }
      95%, 100% { background-color: rgba(255,255,255,0.15); box-shadow: none; }
    }
    @keyframes agent2-dot {
      0%, 21%   { background-color: rgba(255,255,255,0.15); box-shadow: none; }
      23%, 39%  { background-color: rgb(52, 211, 153); box-shadow: 0 0 10px rgba(52, 211, 153, 0.7); }
      43%, 90%  { background-color: rgba(52, 211, 153, 0.5); box-shadow: none; }
      95%, 100% { background-color: rgba(255,255,255,0.15); box-shadow: none; }
    }
    @keyframes agent3-dot {
      0%, 42%   { background-color: rgba(255,255,255,0.15); box-shadow: none; }
      44%, 60%  { background-color: rgb(52, 211, 153); box-shadow: 0 0 10px rgba(52, 211, 153, 0.7); }
      64%, 90%  { background-color: rgba(52, 211, 153, 0.5); box-shadow: none; }
      95%, 100% { background-color: rgba(255,255,255,0.15); box-shadow: none; }
    }
    @keyframes agent4-dot {
      0%, 63%   { background-color: rgba(255,255,255,0.15); box-shadow: none; }
      65%, 81%  { background-color: rgb(52, 211, 153); box-shadow: 0 0 10px rgba(52, 211, 153, 0.7); }
      85%, 90%  { background-color: rgba(52, 211, 153, 0.5); box-shadow: none; }
      95%, 100% { background-color: rgba(255,255,255,0.15); box-shadow: none; }
    }

    .agent-output {
      transform: scaleX(0);
      transform-origin: left;
      animation-duration: 14s;
      animation-iteration-count: infinite;
      animation-timing-function: ease-out;
      animation-delay: 0s;
    }
    .agent-output-1 { animation-name: agent1-bar; }
    .agent-output-2 { animation-name: agent2-bar; }
    .agent-output-3 { animation-name: agent3-bar; }
    .agent-output-4 { animation-name: agent4-bar; }

    @keyframes agent1-bar {
      0%, 2%    { transform: scaleX(0); }
      18%, 90%  { transform: scaleX(1); }
      95%, 100% { transform: scaleX(0); }
    }
    @keyframes agent2-bar {
      0%, 23%   { transform: scaleX(0); }
      39%, 90%  { transform: scaleX(1); }
      95%, 100% { transform: scaleX(0); }
    }
    @keyframes agent3-bar {
      0%, 44%   { transform: scaleX(0); }
      60%, 90%  { transform: scaleX(1); }
      95%, 100% { transform: scaleX(0); }
    }
    @keyframes agent4-bar {
      0%, 65%   { transform: scaleX(0); }
      81%, 90%  { transform: scaleX(1); }
      95%, 100% { transform: scaleX(0); }
    }

    .log-line {
      opacity: 0;
      transform: translateY(4px);
      animation-duration: 14s;
      animation-iteration-count: infinite;
      animation-timing-function: ease-out;
      animation-delay: 0s;
    }
    .log-1 { animation-name: log1; }
    .log-2 { animation-name: log2; }
    .log-3 { animation-name: log3; }
    .log-4 { animation-name: log4; }
    .log-5 { animation-name: log5; }

    @keyframes log1 {
      0%, 9%    { opacity: 0; transform: translateY(4px); }
      11%, 90%  { opacity: 1; transform: translateY(0); }
      94%, 100% { opacity: 0; transform: translateY(0); }
    }
    @keyframes log2 {
      0%, 30%   { opacity: 0; transform: translateY(4px); }
      32%, 90%  { opacity: 1; transform: translateY(0); }
      94%, 100% { opacity: 0; transform: translateY(0); }
    }
    @keyframes log3 {
      0%, 51%   { opacity: 0; transform: translateY(4px); }
      53%, 90%  { opacity: 1; transform: translateY(0); }
      94%, 100% { opacity: 0; transform: translateY(0); }
    }
    @keyframes log4 {
      0%, 72%   { opacity: 0; transform: translateY(4px); }
      74%, 90%  { opacity: 1; transform: translateY(0); }
      94%, 100% { opacity: 0; transform: translateY(0); }
    }
    @keyframes log5 {
      0%, 85%   { opacity: 0; transform: translateY(4px); }
      87%, 90%  { opacity: 1; transform: translateY(0); }
      94%, 100% { opacity: 0; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .agent-dot, .agent-output, .log-line { animation: none !important; }
      .agent-dot { background-color: rgb(52, 211, 153) !important; }
      .agent-output { transform: scaleX(1); }
      .log-line { opacity: 1; transform: none; }
    }
  </style>
</figure>
