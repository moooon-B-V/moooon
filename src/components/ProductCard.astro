---
import NotifyForm from './NotifyForm.astro';

interface Props {
  product: 'doooo-app' | 'doooo-hub' | 'prodect';
  index: string;
  name: string;
  tagline: string;
  status?: string;
}

const { product, index, name, tagline, status = 'Coming soon' } = Astro.props;
---

<article id={product} class="group relative border-t border-[var(--color-line)]/15 py-16 md:py-24 first:border-t-0">
  <div class="grid md:grid-cols-12 gap-8 md:gap-16">
    <header class="md:col-span-4">
      <p class="flex items-center gap-3 text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)]">
        <span class="font-mono">{index}</span>
        <span class="inline-block h-px w-6 bg-[var(--color-ink)]/30"></span>
        <span>{status}</span>
      </p>
      <h3 class="mt-5 text-[36px] md:text-[52px] leading-[1] tracking-[-0.025em] font-medium">
        {name}
      </h3>
      <p class="mt-4 text-[16px] md:text-[18px] text-[var(--color-muted)] leading-[1.4]">
        {tagline}
      </p>
    </header>
    <div class="md:col-span-8 md:pl-8 md:border-l md:border-[var(--color-line)]/10">
      <div class="prose prose-neutral max-w-none text-[15px] md:text-[16px] leading-[1.65] text-[var(--color-ink)]/85 [&_strong]:text-[var(--color-ink)] [&_strong]:font-medium">
        <slot />
      </div>
      <NotifyForm product={product} />
    </div>
  </div>
</article>
