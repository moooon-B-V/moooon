<section class="mx-auto max-w-6xl px-6 md:px-10 pt-20 md:pt-32 pb-20 md:pb-32">
  <p class="text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)] mb-8 md:mb-12 flex items-center gap-3">
    <span class="inline-block h-px w-8 bg-[var(--color-ink)]/30"></span>
    moooon · est. 2026
  </p>
  <h1 class="text-[44px] sm:text-[64px] md:text-[88px] lg:text-[104px] leading-[0.95] tracking-[-0.04em] font-medium">
    Three products.<br />
    One small team.<br />
    <span class="text-[var(--color-brand)]">Built by the tool<br />we're building.</span>
  </h1>
  <div class="mt-10 md:mt-14 max-w-xl text-[15px] md:text-[16px] leading-[1.55] text-[var(--color-muted)]">
