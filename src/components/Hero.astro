    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="animate-pulse">
      <path d="M10 4v12m0 0l-4-4m4 4l4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
