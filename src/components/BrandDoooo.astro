---
interface Props {
  /** Text containing the word "Taq". Every "Taq" occurrence is replaced with the styled mark. */
  text?: string;
  /** Optional wrapper class. */
  class?: string;
  /** Color the accent letter in brand indigo. Default true. */
  colored?: boolean;
}

const { text, class: className = '', colored = true } = Astro.props;

const accentColorClass = colored ? 'text-[var(--color-brand)]' : '';

const parts = text === undefined ? null : text.split('Taq');
---

<!--
  Visual mark for "Taq": the whole word is rendered in the brand accent color.
-->

{parts === null ? (
  <span class:list={['normal-case', accentColorClass, className]}>Taq</span>
) : (
  <span class={className}>
    {parts.map((part, i) => (
      <>
        {part}
        {i < parts.length - 1 && (
          <span class:list={['normal-case', accentColorClass]}>Taq</span>
        )}
      </>
    ))}
  </span>
)}
