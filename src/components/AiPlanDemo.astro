---
import BrandDoooo from './BrandDoooo.astro';
---

<figure class="not-prose my-8">
  <div
    class="relative overflow-hidden rounded-2xl border border-[var(--color-line)]/15 bg-gradient-to-br from-[#f5f0ff] via-[#fff5ee] to-[#fef4f1] p-5 md:p-7 shadow-[0_2px_8px_-2px_rgba(10,10,10,0.05),0_24px_60px_-32px_rgba(54,14,255,0.18)]"
  >
    <!-- Phone-shaped frame -->
    <div
      class="mx-auto max-w-[420px] rounded-[28px] border border-black/10 bg-white shadow-[0_30px_60px_-30px_rgba(10,10,10,0.25)] overflow-hidden"
    >
      <!-- Status bar -->
      <div class="flex items-center justify-between px-5 pt-3 pb-2 text-[10px] text-[var(--color-muted)]">
        <span>9:41</span>
        <span class="flex gap-1">
          <span class="inline-block w-3 h-2 rounded-sm bg-[var(--color-ink)]/40"></span>
          <span class="inline-block w-3 h-2 rounded-sm bg-[var(--color-ink)]/40"></span>
          <span class="inline-block w-4 h-2 rounded-sm bg-[var(--color-ink)]/60"></span>
        </span>
      </div>

      <!-- Header -->
      <div class="px-5 pb-3 border-b border-black/5 flex items-center gap-2">
        <span class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-muted)]"><BrandDoooo /></span>
        <span class="ml-auto text-[10px] text-[var(--color-muted)]">AI Planner</span>
      </div>

      <!-- Animation stage -->
      <div class="relative h-[360px]">
        <!-- Frame 1: Chat input typing -->
        <div class="absolute inset-0 demo-frame demo-frame-1 px-5 py-6 flex flex-col justify-end">
          <div class="text-[13px] text-[var(--color-muted)] mb-3 leading-relaxed">
            Tell me what you want to do. I'll make a plan.
          </div>
          <div class="rounded-2xl bg-[var(--color-paper-2)] border border-black/5 px-4 py-3 text-[14px] text-[var(--color-ink)] leading-[1.4]">
            <span class="typing-text">Learn guitar in 6 weeks</span><span class="caret">|</span>
          </div>
        </div>

        <!-- Frame 2: Planner acknowledges the intent -->
        <div class="absolute inset-0 demo-frame demo-frame-2 px-5 py-6 flex flex-col justify-end">
          <div class="space-y-2 mb-3">
            <div class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-muted)]">Planner</div>
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-brand)]/10 border border-[var(--color-brand)]/20 text-[12px] font-semibold text-[var(--color-brand)]">
              <span class="text-[10px]">●</span>
              Got it — a 6-week learning plan.
            </div>
            <div class="text-[12px] text-[var(--color-muted)] leading-relaxed">
              I'll stagger the practice, add a few video resources, and ramp up slowly.
            </div>
          </div>
          <div class="rounded-2xl bg-[var(--color-paper-2)] border border-black/5 px-4 py-3 text-[14px] text-[var(--color-ink)]/70 leading-[1.4]">
            Learn guitar in 6 weeks
          </div>
        </div>

        <!-- Frame 3: Generated plan -->
        <div class="absolute inset-0 demo-frame demo-frame-3 px-5 py-5 flex flex-col">
          <div class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-muted)] mb-3">
            Your 6-week plan · 18 tasks
          </div>
          <div class="space-y-1.5 overflow-hidden">
            <div class="plan-row plan-row-1 flex items-center gap-2.5 px-3 py-2 rounded-lg bg-[var(--color-paper-2)] text-[12px]">
              <span class="text-[10px] text-[var(--color-brand)]">●</span>
              <span class="font-semibold">Tune the guitar</span>
              <span class="ml-auto text-[10px] text-[var(--color-muted)]">Mon · 15m</span>
            </div>
            <div class="plan-row plan-row-2 flex items-center gap-2.5 px-3 py-2 rounded-lg bg-[var(--color-paper-2)] text-[12px]">
              <span class="text-[10px] text-[var(--color-brand)]">●</span>
              <span class="font-semibold">First chord: G major</span>
              <span class="ml-auto text-[10px] text-[var(--color-muted)]">Tue · 30m</span>
            </div>
            <div class="plan-row plan-row-3 flex items-center gap-2.5 px-3 py-2 rounded-lg bg-[var(--color-paper-2)] text-[12px]">
              <span class="text-[10px] text-[var(--color-brand)]">●</span>
              <span class="font-semibold">Rest day · listen to playlist</span>
              <span class="ml-auto text-[10px] text-[var(--color-muted)]">Wed</span>
            </div>
            <div class="plan-row plan-row-4 flex items-center gap-2.5 px-3 py-2 rounded-lg bg-[var(--color-paper-2)] text-[12px]">
              <span class="text-[10px] text-[var(--color-brand)]">●</span>
              <span class="font-semibold">Second chord: C major</span>
              <span class="ml-auto text-[10px] text-[var(--color-muted)]">Thu · 30m</span>
            </div>
            <div class="plan-row plan-row-5 flex items-center gap-2.5 px-3 py-2 rounded-lg bg-[var(--color-paper-2)] text-[12px]">
              <span class="text-[10px] text-[var(--color-brand)]">●</span>
              <span class="font-semibold">Switch between G ↔ C</span>
              <span class="ml-auto text-[10px] text-[var(--color-muted)]">Sat · 45m</span>
            </div>
            <div class="plan-row plan-row-6 flex items-center gap-2.5 px-3 py-2 rounded-lg bg-[var(--color-paper-2)] text-[12px] text-[var(--color-muted)]">
              <span class="text-[10px]">●</span>
              <span>Week 2 · D major + first song</span>
              <span class="ml-auto text-[10px]">…</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <figcaption class="mt-5 text-center text-[12px] text-[var(--color-muted)] leading-[1.5]">
      <span class="text-[var(--color-ink)] font-medium">Tell <BrandDoooo /> what you want.</span>
      Learn a skill, train for a race, build a side project, plan an event, lock in a daily routine — it figures out what kind of plan you need and paces it like one.
    </figcaption>
  </div>

  <style>
    .demo-frame {
      animation: doooo-cycle 12s ease-in-out infinite;
      opacity: 0;
    }
    .demo-frame-1 { animation-delay: 0s; }
    .demo-frame-2 { animation-delay: 4s; }
    .demo-frame-3 { animation-delay: 8s; }

    @keyframes doooo-cycle {
      0%, 2%   { opacity: 0; transform: translateY(8px); }
      4%, 30%  { opacity: 1; transform: translateY(0); }
      33%, 100% { opacity: 0; transform: translateY(-8px); }
    }

    /* Typewriter effect: width animates from 0 to 100% via inline-block + max-width */
    .typing-text {
      display: inline-block;
      overflow: hidden;
      white-space: nowrap;
      max-width: 0;
      vertical-align: bottom;
      animation: type-it 12s steps(22, end) infinite;
    }
    @keyframes type-it {
      0%   { max-width: 0; }
      18%  { max-width: 20ch; }
      33%, 100% { max-width: 20ch; }
    }
    .caret {
      display: inline-block;
      animation: blink 1s steps(2, end) infinite, caret-fade 12s linear infinite;
      color: var(--color-brand);
      font-weight: 300;
      margin-left: 1px;
    }
    @keyframes blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }
    @keyframes caret-fade {
      0%, 30% { opacity: 1; }
      33%, 100% { opacity: 0; }
    }

    /* Plan rows stagger-in during frame 3 */
    .plan-row {
      opacity: 0;
      transform: translateX(-6px);
      animation: plan-row-in 12s ease-out infinite;
    }
    .plan-row-1 { animation-delay: 8.1s; }
    .plan-row-2 { animation-delay: 8.35s; }
    .plan-row-3 { animation-delay: 8.6s; }
    .plan-row-4 { animation-delay: 8.85s; }
    .plan-row-5 { animation-delay: 9.1s; }
    .plan-row-6 { animation-delay: 9.35s; }
    @keyframes plan-row-in {
      0%, 0.5%  { opacity: 0; transform: translateX(-6px); }
      2%, 30%   { opacity: 1; transform: translateX(0); }
      33%, 100% { opacity: 0; transform: translateX(-6px); }
    }

    @media (prefers-reduced-motion: reduce) {
      .demo-frame, .typing-text, .caret, .plan-row {
        animation: none !important;
      }
      .demo-frame-3 { opacity: 1; }
    }
  </style>
</figure>
