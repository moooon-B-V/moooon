---
interface Props {
  product: 'doooo-app' | 'doooo-hub' | 'prodect';
}
const { product } = Astro.props;
---

<form
  data-notify-form
  data-product={product}
  class="mt-6 flex flex-col sm:flex-row gap-2"
  novalidate
>
  <label class="sr-only" for={`notify-${product}`}>Your email address</label>
  <input
    type="email"
    id={`notify-${product}`}
    name="email"
    required
    autocomplete="email"
    placeholder="you@somewhere.com"
    class="flex-1 px-4 py-3 text-[14px] bg-[var(--color-paper)] border border-[var(--color-ink)]/20 rounded-md focus:outline-none focus:border-[var(--color-brand)] focus:ring-2 focus:ring-[var(--color-brand)]/20 transition placeholder:text-[var(--color-muted)]"
  />
  <input type="hidden" name="product" value={product} />
  <button
    type="submit"
    class="px-5 py-3 text-[14px] font-medium bg-[var(--color-ink)] text-white rounded-md hover:bg-[var(--color-brand)] transition-colors disabled:opacity-50 disabled:cursor-not-allowed inline-flex items-center justify-center gap-2 group"
  >
    <span data-notify-label>Notify me</span>
    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      class="transition-transform group-hover:translate-x-0.5"
    >
      <path d="M3 7h8m0 0L7.5 3.5M11 7l-3.5 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
</form>
<p data-notify-status class="mt-2 text-[12px] text-[var(--color-muted)] min-h-[1em]" aria-live="polite"></p>

<script>
  const forms = document.querySelectorAll<HTMLFormElement>('form[data-notify-form]');
  forms.forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const status = form.parentElement?.querySelector<HTMLElement>('[data-notify-status]');
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const label = form.querySelector<HTMLElement>('[data-notify-label]');
      const emailInput = form.querySelector<HTMLInputElement>('input[name="email"]');
      const email = emailInput?.value.trim() ?? '';
      const product = form.dataset.product ?? 'unknown';

      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (status) {
          status.textContent = 'That email doesn\'t look right.';
          status.style.color = '#b00020';
        }
        return;
      }

      if (button) button.disabled = true;
      if (label) label.textContent = 'Sending…';
      if (status) {
        status.textContent = '';
        status.style.color = '';
      }

      try {
        const res = await fetch('/api/notify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, product }),
        });
        if (!res.ok) throw new Error(`status ${res.status}`);
        if (status) {
          status.textContent = 'You\'re on the list. We\'ll only email when there\'s something to show.';
          status.style.color = '#360eff';
        }
        if (emailInput) emailInput.value = '';
        if (label) label.textContent = 'Subscribed';
      } catch {
        if (status) {
          status.textContent = 'Something went wrong. Try again in a minute.';
          status.style.color = '#b00020';
        }
        if (label) label.textContent = 'Notify me';
        if (button) button.disabled = false;
      }
    });
  });
</script>
