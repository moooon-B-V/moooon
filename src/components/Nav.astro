---
import BrandDoooo from './BrandDoooo.astro';
import { t, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}
const { lang = 'en' } = Astro.props;
const homeHref = lang === 'zh' ? '/zh' : '/';
---

<!-- Top floating pill (default) -->
<nav
  data-nav-top
  class="nav-top fixed top-3 md:top-4 inset-x-3 md:inset-x-6 z-50 transition-all duration-500 ease-out"
>
  <div
    class="mx-auto max-w-7xl rounded-full px-4 md:px-9 py-2.5 md:py-5 flex items-center justify-between gap-3
           bg-white/55 backdrop-blur-xl backdrop-saturate-150
           border border-white/40
           shadow-[0_1px_2px_rgba(10,10,10,0.04),0_8px_28px_-12px_rgba(54,14,255,0.18),0_24px_60px_-32px_rgba(255,180,140,0.35)]"
  >
    <a href={homeHref} class="group shrink-0" aria-label="MOOOON home">
      <span
        class="text-[28px] md:text-[40px] leading-none tracking-[0.02em] transition-transform group-hover:scale-[1.02]"
        style="font-family: 'Nabla', system-ui, sans-serif; font-feature-settings: 'palt';"
      >MOOOON</span>
    </a>
    <div class="flex items-center gap-3 md:gap-8 text-[12px] md:text-[16px] font-semibold text-[var(--color-ink)]/75 whitespace-nowrap">
      <a href={`${homeHref}#doooo-app`} class="hover:text-[var(--color-ink)] transition-colors"><BrandDoooo /> App</a>
      <a href={`${homeHref}#doooo-hub`} class="hover:text-[var(--color-ink)] transition-colors"><BrandDoooo /> Hub</a>
      <a href={`${homeHref}#prodect`} class="hover:text-[var(--color-ink)] transition-colors">Prodect</a>
      <a href="mailto:info@moooon.net" class="hidden md:inline hover:text-[var(--color-ink)] transition-colors">{t(lang, 'navContact')}</a>
      <a href="mailto:info@moooon.net" aria-label={t(lang, 'navContactAria')} class="md:hidden text-[var(--color-ink)]/60 hover:text-[var(--color-ink)] transition-colors">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="5" width="18" height="14" rx="2"/>
          <path d="M3 7l9 6 9-6"/>
        </svg>
      </a>
    </div>
  </div>
</nav>

<!-- Side rail (desktop only; hidden on mobile) -->
<nav
  data-nav-side
  aria-label="Section navigation"
  class="nav-side hidden md:block fixed left-5 top-1/2 -translate-y-1/2 z-50 pointer-events-none opacity-0 transition-all duration-500 ease-out"
>
  <div
    class="flex flex-col items-center gap-12 px-3 py-12 rounded-full
           bg-white/55 backdrop-blur-xl backdrop-saturate-150
           border border-white/40
           shadow-[0_1px_2px_rgba(10,10,10,0.04),0_8px_28px_-12px_rgba(54,14,255,0.18),0_24px_60px_-32px_rgba(255,180,140,0.35)]"
  >
    <a href={homeHref} class="group" aria-label="MOOOON home">
      <span
        class="block leading-[0.7] transition-transform group-hover:scale-[1.04]"
        style="
          font-family: 'Nabla', system-ui, sans-serif;
          font-feature-settings: 'palt';
          font-size: 40px;
          writing-mode: vertical-rl;
          text-orientation: upright;
          letter-spacing: -0.4em;
        "
      >MOOOON</span>
    </a>

    <div class="h-px w-5 bg-[var(--color-ink)]/15"></div>

    <div class="flex flex-col items-start gap-6 text-[13px] font-semibold text-[var(--color-ink)]/75 px-1">
      <a href={`${homeHref}#doooo-app`} class="hover:text-[var(--color-ink)] transition-colors whitespace-nowrap"><BrandDoooo /> App</a>
      <a href={`${homeHref}#doooo-hub`} class="hover:text-[var(--color-ink)] transition-colors whitespace-nowrap"><BrandDoooo /> Hub</a>
      <a href={`${homeHref}#prodect`} class="hover:text-[var(--color-ink)] transition-colors whitespace-nowrap">Prodect</a>
    </div>

    <div class="h-px w-5 bg-[var(--color-ink)]/15"></div>

    <a
      href="mailto:info@moooon.net"
      aria-label={t(lang, 'navContactAria')}
      class="text-[var(--color-ink)]/60 hover:text-[var(--color-ink)] transition-colors"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="5" width="18" height="14" rx="2"/>
        <path d="M3 7l9 6 9-6"/>
      </svg>
    </a>
  </div>
</nav>

<style>
  /* Desktop only: when body is in "products" mode, top pill fades out and side rail fades in.
     Mobile keeps the top pill always (no side rail on mobile). */
  @media (min-width: 768px) {
    :global(body.nav-mode-side) [data-nav-top] {
      opacity: 0;
      transform: translateY(-12px) scale(0.98);
      pointer-events: none;
    }
    :global(body.nav-mode-side) [data-nav-side] {
      opacity: 1;
      pointer-events: auto;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-nav-top], [data-nav-side] { transition: none !important; }
  }
</style>

<script>
  // Toggle nav layout based on which section is in view.
  const observed = document.querySelectorAll<HTMLElement>('#doooo, #doooo-app, #doooo-hub, #prodect');
  if (observed.length > 0) {
    const visible = new Set<Element>();
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target);
          else visible.delete(e.target);
        }
        document.body.classList.toggle('nav-mode-side', visible.size > 0);
      },
      { rootMargin: '-15% 0px -15% 0px', threshold: 0 }
    );
    observed.forEach((el) => io.observe(el));
  }
</script>
