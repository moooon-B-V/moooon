---
import Home from '../components/Home.astro';

export const prerender = true;
---

<Home lang="en" />

<!--
  Auto-redirect: if the visitor's preferred language starts with "zh", send
  them to /zh. Runs inline before any other JS so the redirect happens fast.
  Only fires on / — /zh has its own script-free page.
-->
<script is:inline>
  (function () {
    try {
      var lang = (navigator.language || navigator.userLanguage || '').toLowerCase();
      if (lang.indexOf('zh') === 0) {
        // Preserve hash if any so deep links still work.
        var hash = window.location.hash || '';
        window.location.replace('/zh' + hash);
      }
    } catch (_) {}
  })();
</script>
