---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;
---

<Layout
  title="Imprint — MOOOON"
  description="Legal information about moooon B.V., the company behind moooon.net."
>
  <Nav />

  <main class="mx-auto max-w-3xl px-6 md:px-10 pt-32 md:pt-40 pb-20 md:pb-32">
    <p class="text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)] mb-6 flex items-center gap-3">
      <span class="inline-block h-px w-8 bg-[var(--color-ink)]/30"></span>
      Imprint
    </p>
    <h1 class="font-hero text-[40px] md:text-[56px] leading-[1.05] tracking-[-0.02em] font-medium">
      Legal information.
    </h1>
    <p class="mt-5 text-[16px] md:text-[17px] text-[var(--color-muted)] leading-[1.55]">
      Information provided in accordance with Article 3:15d of the Dutch Civil Code (BW).
    </p>

    <section class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-y-6 md:gap-y-8 gap-x-10 text-[15px] md:text-[16px] leading-[1.55]">
      <div class="md:col-span-1 text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)]">Entity</div>
      <div class="md:col-span-2">
        <p class="font-semibold">moooon B.V.</p>
        <p class="text-[var(--color-muted)]">Private limited company registered in the Netherlands</p>
      </div>

      <div class="md:col-span-1 text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)]">Registered address</div>
      <div class="md:col-span-2">
        <p>Menkemaborg 65</p>
        <p>Lelystad</p>
        <p>The Netherlands</p>
      </div>

      <div class="md:col-span-1 text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)]">Director</div>
      <div class="md:col-span-2">
        <p>Yue Zhu</p>
      </div>

      <div class="md:col-span-1 text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)]">KVK</div>
      <div class="md:col-span-2">
        <p class="font-mono">97763144</p>
        <p class="text-[var(--color-muted)] text-[13px] mt-1">Dutch Chamber of Commerce</p>
      </div>

      <div class="md:col-span-1 text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)]">VAT</div>
      <div class="md:col-span-2">
        <p class="font-mono">NL868220486B01</p>
        <p class="text-[var(--color-muted)] text-[13px] mt-1">BTW-nummer</p>
      </div>

      <div class="md:col-span-1 text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)]">Contact</div>
      <div class="md:col-span-2">
        <a
          href="mailto:info@moooon.net"
          class="text-[var(--color-brand)] link-underline"
        >info@moooon.net</a>
      </div>
    </section>

    <section class="mt-16 pt-10 border-t border-[var(--color-line)]/15">
      <h2 class="font-display text-[24px] md:text-[28px] leading-[1.2] tracking-[-0.015em] font-medium">
        EU online dispute resolution
      </h2>
      <p class="mt-4 text-[15px] md:text-[16px] text-[var(--color-muted)] leading-[1.65]">
        The European Commission provides a platform for online dispute resolution, available at
        <a href="https://ec.europa.eu/consumers/odr/" target="_blank" rel="noopener" class="text-[var(--color-brand)] link-underline">ec.europa.eu/consumers/odr</a>.
        We are not obliged, nor willing, to participate in dispute resolution proceedings before a consumer arbitration board.
      </p>
    </section>

    <section class="mt-12">
      <h2 class="font-display text-[24px] md:text-[28px] leading-[1.2] tracking-[-0.015em] font-medium">
        Liability
      </h2>
      <p class="mt-4 text-[15px] md:text-[16px] text-[var(--color-muted)] leading-[1.65]">
        The content of this site has been prepared with care. We make no warranty as to the accuracy, completeness, or
        timeliness of the information provided. Links to external websites are provided for convenience; we have no
        control over and accept no responsibility for the content of those sites.
      </p>
    </section>
  </main>

  <Footer />
</Layout>
