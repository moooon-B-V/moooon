---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

export const prerender = true;

const policyUrl = 'https://www.iubenda.com/privacy-policy/73390507';
---

<Layout
  title="Privacy Policy — MOOOON"
  description="How moooon B.V. handles personal data on moooon.net."
>
  <Nav />

  <main class="mx-auto max-w-3xl px-6 md:px-10 pt-32 md:pt-40 pb-20 md:pb-32">
    <p class="text-[12px] uppercase tracking-[0.18em] text-[var(--color-muted)] mb-6 flex items-center gap-3">
      <span class="inline-block h-px w-8 bg-[var(--color-ink)]/30"></span>
      Privacy
    </p>
    <h1 class="font-hero text-[40px] md:text-[56px] leading-[1.05] tracking-[-0.02em] font-medium">
      Privacy policy.
    </h1>
    <p class="mt-5 text-[16px] md:text-[17px] text-[var(--color-muted)] leading-[1.55]">
      Hosted by iubenda. Updated automatically as privacy laws change.
      <a href={policyUrl} target="_blank" rel="noopener" class="text-[var(--color-brand)] link-underline">View on iubenda &rarr;</a>
    </p>

    <!--
      iubenda no-iframe embed. The script auto-finds .iubenda-embed elements
      with class iubenda-noiframe, fetches the policy HTML from the linked URL,
      and injects it inline. Renders the full policy as part of our page —
      no iframe, no modal.
    -->
    <div class="iubenda-policy mt-12 prose prose-neutral max-w-none">
      <a
        href={policyUrl}
        class="iubenda-white no-brand iubenda-noiframe iubenda-embed"
        title="Privacy Policy"
      >Privacy Policy</a>
    </div>

    <!-- iubenda loader lives in Layout.astro; runs on every page automatically. -->

    <p class="mt-12 pt-6 border-t border-[var(--color-line)]/15 text-[14px] text-[var(--color-muted)] leading-[1.6]">
      See also our <a href="/terms" class="text-[var(--color-brand)] link-underline">Terms of Use</a> and
      <a href="/imprint" class="text-[var(--color-brand)] link-underline">Imprint</a>.
    </p>
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Style iubenda's injected HTML to fit our typography. */
  .iubenda-policy h1, .iubenda-policy h2, .iubenda-policy h3, .iubenda-policy h4 {
    font-family: var(--font-display);
    color: var(--color-ink);
  }
  .iubenda-policy h1 { display: none; } /* hide iubenda's own H1 — we have one */
  .iubenda-policy h2 {
    font-size: 24px;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .iubenda-policy h3 {
    font-size: 18px;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .iubenda-policy p {
    font-size: 16px;
    line-height: 1.65;
    color: var(--color-ink);
    opacity: 0.85;
    margin: 0.75rem 0;
  }
  .iubenda-policy a {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .iubenda-policy ul, .iubenda-policy ol {
    padding-left: 1.5rem;
    margin: 0.75rem 0;
  }
  .iubenda-policy li {
    font-size: 16px;
    line-height: 1.6;
    margin: 0.4rem 0;
  }
</style>
